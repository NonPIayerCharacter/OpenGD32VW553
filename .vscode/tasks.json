            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Download MBL (JLink)",
            "type": "shell",
            "args": ["MBL", "JLink"],
            "windows": {
                "command": "${workspaceFolder}/.vscode/download.bat"
            },
