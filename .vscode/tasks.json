            ]
        },
        {
            "label": "Start OpenOCD (GDLink)",
            "type": "shell",
            "windows": {
                "command": "cmd",
                "args": [
                    "/c",
                    "\"${workspaceFolder}/tools/xpack-openocd-0.11.0-3_windows/bin/openocd.exe\" -f \"${workspaceFolder}/MSDK/projects/eclipse/msdk/openocd_gdlink.cfg\""
                ]
            },
            "linux": {
                "command": "bash",
                "args": [
                    "-c",
                    "\"${workspaceFolder}/tools/xpack-openocd-0.11.0-3_linux/bin/openocd\" -f \"${workspaceFolder}/MSDK/projects/eclipse/msdk/openocd_gdlink.cfg\""
                ]
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "^.*$",
                    "file": 1,
                    "location": 2,
                    "message": 3
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^.*Open On-Chip Debugger.*",
                    "endsPattern": "^.*Listening on port.*"
                }
            }
        },
        {
            "label": "Start OpenOCD (JLink)",
            "type": "shell",
            "windows": {
                "command": "cmd",
                "args": [
                    "/c",
                    "\"${workspaceFolder}/tools/xpack-openocd-0.11.0-3_windows/bin/openocd.exe\" -f \"${workspaceFolder}/MSDK/projects/eclipse/msdk/openocd_jlink.cfg\""
                ]
