{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build MSDK",
            "type": "shell",
            "args": [
                "app",
                "msdk"
            ],
            "windows": {
                "command": "${workspaceFolder}/cmake_build.bat"
            },
            "linux": {
                "command": "${workspaceFolder}/cmake_build.sh"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "Build MBL",
            "type": "shell",
            "args": [
                "app",
                "mbl"
            ],
            "windows": {
                "command": "${workspaceFolder}/cmake_build.bat"
            },
            "linux": {
                "command": "${workspaceFolder}/cmake_build.sh"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "Build ALL",
            "type": "shell",
            "args": [
                "app"
            ],
            "windows": {
                "command": "${workspaceFolder}/cmake_build.bat"
            },
            "linux": {
                "command": "${workspaceFolder}/cmake_build.sh"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "Clean ALL",
            "type": "shell",
            "args": [
                "app",
                "clean"
            ],
            "windows": {
                "command": "${workspaceFolder}/cmake_build.bat"
            },
            "linux": {
                "command": "${workspaceFolder}/cmake_build.sh"
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "Download MSDK (GDLink)",
            "type": "shell",
            "args": ["MSDK", "GDLink"],
            "windows": {
                "command": "${workspaceFolder}/.vscode/download.bat"
            },
            "linux": {
                "command": "${workspaceFolder}/.vscode/download.sh"
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Download MBL (GDLink)",
            "type": "shell",
            "args": ["MBL", "GDLink"],
            "windows": {
                "command": "${workspaceFolder}/.vscode/download.bat"
            },
            "linux": {
                "command": "${workspaceFolder}/.vscode/download.sh"
            },
